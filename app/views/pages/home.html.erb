<section class="grid gap-8 sm:grid-cols-5">
  <div class="sm:col-span-3">
    <p class="mb-2 text-xs uppercase tracking-[0.2em] text-amber-300">Overview</p>
    <h1 class="text-3xl font-semibold tracking-tight text-stone-100 sm:text-4xl">
      <%= @about["name"] %>
    </h1>
    <p class="mt-3 text-lg text-stone-300"><%= @about["tagline"] %></p>
    <p class="mt-6 max-w-2xl leading-7 text-stone-300"><%= @about["bio"] %></p>
  </div>

  <div class="rounded-xl border border-stone-800 bg-stone-900/40 p-5 sm:col-span-2">
    <h2 class="text-sm font-semibold uppercase tracking-[0.15em] text-stone-400">Current focus</h2>
    <ul class="mt-4 space-y-2 text-sm text-stone-300">
      <li>Moving away from a lifetime of Windows usage and distro-hopping until I either get bored or find one I can actually stick with.</li>
      <li>Continuing work with infrastructure-as-code and reliable automation.</li>
    </ul>
  </div>
</section>

<section class="mt-12">
  <div class="mb-4 flex items-center justify-between">
    <h2 class="text-xl font-semibold text-stone-100">Featured projects</h2>
    <%= link_to "View all", projects_path, class: "text-sm text-amber-300 hover:text-amber-200" %>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <% @featured_projects.each do |project| %>
      <article class="rounded-xl border border-stone-800 bg-stone-900/40 p-5">
        <h3 class="font-medium text-stone-100"><%= project["title"] %></h3>
        <p class="mt-2 text-sm leading-6 text-stone-300"><%= project["description"] %></p>
      </article>
    <% end %>
  </div>
</section>