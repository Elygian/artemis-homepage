<section>
  <p class="mb-2 text-xs uppercase tracking-[0.2em] text-amber-300">Network</p>
  <h1 class="text-3xl font-semibold tracking-tight text-stone-100">Contact</h1>

  <div class="mt-8 grid gap-3 sm:grid-cols-2">
    <% @links.each do |link| %>
      <%= link_to link["url"], target: "_blank", rel: "noopener",
          class: "rounded-xl border border-stone-800 bg-stone-900/40 p-4 transition hover:border-amber-300/50 hover:bg-stone-900" do %>
        <p class="text-sm font-medium text-stone-100"><%= link["label"] %></p>
        <p class="mt-1 text-xs text-stone-400"><%= link["url"] %></p>
      <% end %>
    <% end %>
  </div>
</section>